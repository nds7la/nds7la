// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTH & USERS
// ============================================================================

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String     // bcrypted
  name      String?
  role      UserRole   @default(ADMIN)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  logs      Log[]
  sessions  Session[]

  @@index([email])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([token])
}

enum UserRole {
  ADMIN
  EDITOR
}

// ============================================================================
// RSS SOURCES
// ============================================================================

model RssSource {
  id              String    @id @default(cuid())
  name            String
  url             String    @unique
  category        String    // science, tech, health, environment, etc
  language        String    @default("en")
  country         String?   // US, CA, UK, etc
  trustScore      Int       @default(80)
  isActive        Boolean   @default(true)
  fetchFrequency  Int       @default(60) // minutes
  priority        Int       @default(0)
  tags            String[]  @default([])
  notes           String?
  lastFetchedAt   DateTime?
  lastSuccessAt   DateTime?
  lastErrorAt     DateTime?
  lastErrorMsg    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  articles        Article[]

  @@index([isActive])
  @@index([category])
  @@index([trustScore])
}

// ============================================================================
// ARTICLES & CONTENT
// ============================================================================

model Article {
  id                  String    @id @default(cuid())
  title               String
  originalUrl         String
  sourceId            String
  source              RssSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceTitle         String?
  publishedAt         DateTime
  fetchedAt           DateTime  @default(now())
  
  // Raw content
  description         String?   @db.Text
  content             String?   @db.Text
  
  // Processing status
  status              ArticleStatus @default(NEW)
  isDuplicate         Boolean   @default(false)
  duplicateOf         String?
  
  // Scores & analysis
  aiAnalysis          AiAnalysis?
  positivityScore     Int?
  relevanceScore      Int?
  noveltyScore        Int?
  overallScore        Int?
  
  // Generated content
  generatedContent    GeneratedContent?
  generatedImage      GeneratedImage?
  
  // Publishing
  publishingQueue     PublishingQueueItem?
  publishingResults   PublishingResult[]
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([sourceId])
  @@index([status])
  @@index([isDuplicate])
  @@index([publishedAt])
  @@unique([originalUrl])
}

enum ArticleStatus {
  NEW
  QUEUED
  ANALYZED
  REJECTED
  APPROVED
  READY_FOR_CONTENT
  CONTENT_GENERATED
  IMAGE_PENDING
  IMAGE_GENERATED
  READY_TO_PUBLISH
  PUBLISHED
  FAILED
}

// ============================================================================
// AI ANALYSIS
// ============================================================================

model AiAnalysis {
  id                    String    @id @default(cuid())
  articleId             String    @unique
  article               Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  
  titleCleaned          String
  oneSentenceSummary    String
  fullSummary           String    @db.Text
  languageDetected      String
  category              String
  subcategory           String?
  sentiment             String    // positive, neutral, negative
  positivityScore       Int       // 1-100
  relevanceScore        Int       // 1-100
  noveltyScore          Int       // 1-100
  viralityScore         Int       // 1-100
  trustworthinessScore  Int       // 1-100
  shouldUse             Boolean
  rejectionReason       String?
  suggestedAngle        String?
  keyPoints             String[]  // JSON array
  keywords              String[]
  imagePromptBase       String?   @db.Text
  factSafetyNote        String?
  
  rawResponse           String?   @db.Text // Store raw Claude response for debugging
  processingTime        Int?      // milliseconds
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([articleId])
}

// ============================================================================
// GENERATED CONTENT
// ============================================================================

model GeneratedContent {
  id              String    @id @default(cuid())
  articleId       String    @unique
  article         Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  
  // Universal content
  masterSummary   String    @db.Text
  seoTitle        String
  metaDescription String
  suggestedHashtags String[]  @default([])
  
  // Platform-specific content
  telegramText    String    @db.Text
  twitterText     String    @db.Text
  instagramCaption String   @db.Text
  facebookPost    String    @db.Text
  pinterestDescription String @db.Text
  websiteArticle  String    @db.Text
  pushNotification String?
  
  // Metadata
  generationModel String    @default("claude-sonnet-4")
  generationTime  Int?      // milliseconds
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([articleId])
}

// ============================================================================
// IMAGE GENERATION
// ============================================================================

model GeneratedImage {
  id                String    @id @default(cuid())
  articleId         String    @unique
  article           Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  
  // Image metadata
  imagePrompt       String    @db.Text
  imageUrl          String?
  localPath         String?
  status            ImageStatus @default(NOT_REQUESTED)
  
  // Platform-specific variants
  telegramUrl       String?
  twitterUrl        String?
  instagramUrl      String?
  facebookUrl       String?
  pinterestUrl      String?
  websiteUrl        String?
  
  // Generation details
  generationModel   String    @default("flux-pro")
  width             Int       @default(1080)
  height            Int       @default(608)
  generationTime    Int?      // milliseconds
  failureReason     String?
  retryCount        Int       @default(0)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([articleId])
  @@index([status])
}

enum ImageStatus {
  NOT_REQUESTED
  PROMPT_READY
  GENERATING
  GENERATED
  FAILED
  MANUALLY_UPLOADED
}

// ============================================================================
// PUBLISHING
// ============================================================================

model PublishingQueueItem {
  id              String    @id @default(cuid())
  articleId       String    @unique
  article         Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  
  status          PublishStatus @default(DRAFT)
  scheduledAt     DateTime?
  publishedAt     DateTime?
  
  platforms       Platform[] @default([])
  notes           String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([scheduledAt])
}

enum PublishStatus {
  DRAFT
  READY
  SCHEDULED
  PUBLISHING
  PUBLISHED
  PARTIAL_FAILURE
  FAILED
  PAUSED
}

enum Platform {
  TELEGRAM
  TWITTER
  INSTAGRAM
  FACEBOOK
  PINTEREST
  WEBSITE
}

model PublishingResult {
  id              String    @id @default(cuid())
  articleId       String
  article         Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  
  platform        Platform
  status          PublishResultStatus
  externalPostId  String?
  externalUrl     String?
  
  publishedAt     DateTime
  lastAttemptAt   DateTime  @default(now())
  failureReason   String?
  retryCount      Int       @default(0)
  
  responseData    String?   @db.Text // Raw API response
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([articleId])
  @@index([platform])
  @@index([status])
}

enum PublishResultStatus {
  PENDING
  SUCCESS
  FAILED
  PARTIAL
}

// ============================================================================
// PLATFORM CONNECTIONS
// ============================================================================

model PlatformConnection {
  id              String    @id @default(cuid())
  platform        Platform  @unique
  
  isConnected     Boolean   @default(false)
  authType        AuthType  @default(API_KEY)
  
  // Credentials (encrypted in production)
  credentials     String    @db.Text // JSON encrypted
  
  // Status tracking
  lastTestedAt    DateTime?
  lastTestSuccess Boolean   @default(false)
  lastErrorMsg    String?
  
  // Rate limits & quota
  dailyLimit      Int?
  remainingToday  Int?
  resetAt         DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([platform])
}

enum AuthType {
  API_KEY
  OAUTH
  LOGIN_PASSWORD
  BOT_TOKEN
}

// ============================================================================
// SETTINGS & CONFIGURATION
// ============================================================================

model AutomationSettings {
  id              String    @id @default(cuid())
  
  mode            AutomationMode @default(SEMI_AUTO)
  postsPerDay     Int       @default(5)
  quietHoursStart Int?      // hour 0-23
  quietHoursEnd   Int?
  timezone        String    @default("UTC")
  
  // Minimum score thresholds
  minPositivityScore    Int @default(60)
  minRelevanceScore     Int @default(50)
  minTrustScore         Int @default(70)
  
  // Auto-rejection thresholds
  maxRetries            Int @default(3)
  duplicateSimilarityThreshold Int @default(85)
  
  // Platform-specific settings
  telegramEnabled       Boolean @default(true)
  telegramPostsPerDay   Int @default(5)
  
  twitterEnabled        Boolean @default(true)
  twitterPostsPerDay    Int @default(10)
  
  instagramEnabled      Boolean @default(true)
  instagramPostsPerDay  Int @default(2)
  
  facebookEnabled       Boolean @default(true)
  facebookPostsPerDay   Int @default(3)
  
  pinterestEnabled      Boolean @default(true)
  pinterestPostsPerDay  Int @default(3)
  
  websiteEnabled        Boolean @default(true)
  websitePostsPerDay    Int @default(5)
  
  // Auto-publish settings
  autoPublishEnabled    Boolean @default(false)
  emergencyPauseActive  Boolean @default(false)
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

enum AutomationMode {
  SEMI_AUTO
  FULL_AUTO
}

model PromptTemplate {
  id              String    @id @default(cuid())
  name            String    @unique
  category        PromptCategory
  content         String    @db.Text
  variables       String[]  @default([]) // e.g., [{{article_title}}, {{category}}]
  isDefault       Boolean   @default(false)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([category])
}

enum PromptCategory {
  AI_ANALYSIS
  TELEGRAM_GENERATION
  TWITTER_GENERATION
  INSTAGRAM_GENERATION
  FACEBOOK_GENERATION
  PINTEREST_GENERATION
  WEBSITE_GENERATION
  IMAGE_PROMPT_GENERATION
  POSITIVITY_FILTER
  DUPLICATE_DETECTION
}

model ContentFilter {
  id              String    @id @default(cuid())
  name            String
  
  includeKeywords String[]  @default([])
  excludeKeywords String[]  @default([])
  categoryWhitelist String[] @default([])
  categoryBlacklist String[] @default([])
  sourceWhitelist String[]  @default([])
  sourceBlacklist String[]  @default([])
  
  minPositivityThreshold Int @default(50)
  
  excludePolitical Boolean @default(true)
  excludeTragedy   Boolean @default(true)
  excludeViolence  Boolean @default(true)
  excludeWar       Boolean @default(true)
  excludeGossip    Boolean @default(true)
  
  isActive        Boolean @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================================================
// LOGS & MONITORING
// ============================================================================

model Log {
  id              String    @id @default(cuid())
  userId          String?
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  category        LogCategory
  level           LogLevel
  message         String
  details         String?   @db.Text
  
  articleId       String?
  platform        Platform?
  
  createdAt       DateTime  @default(now())

  @@index([category])
  @@index([level])
  @@index([articleId])
  @@index([createdAt])
}

enum LogCategory {
  RSS_FETCH
  AI_ANALYSIS
  CONTENT_GENERATION
  IMAGE_GENERATION
  PUBLISHING
  PLATFORM_CONNECTION
  SYSTEM
  ERROR
}

enum LogLevel {
  INFO
  WARNING
  ERROR
  DEBUG
}

// ============================================================================
// INDEXES FOR PERFORMANCE
// ============================================================================

// Composite indexes for common queries
model _ArticleStatus {
  @@index([status, createdAt])
  @@index([sourceId, status])
  @@index([isDuplicate, createdAt])
}
